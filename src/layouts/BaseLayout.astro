---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
  image?: string;
  url?: string;
}

const {
  title = 'Kwan Um Zen',
  description = 'Zenová meditácia na Slovensku. Súčasť medzinárodnej školy Kwan Um.',
  lang = 'sk',
  image = '/logo.png',
} = Astro.props;

const fullTitle = title;
// Strip query params to avoid duplicate-content issues
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url.origin).href;
const ogImage = new URL(image, Astro.url).href;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <!-- Primary Meta Tags -->
    <title>{fullTitle}</title>
    <meta name="title" content={fullTitle} />
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={lang === 'sk' ? 'sk_SK' : 'en_US'} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={fullTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />

    <!-- Favicons -->
    <link rel="icon" type="image/svg+xml" href="/logo-white.svg" />
    <link rel="icon" href="/logo-white.svg" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- Browser / PWA hints -->
    <meta name="theme-color" content="#ffffff" />
    <meta name="color-scheme" content="light" />
    <meta name="format-detection" content="telephone=no" />

    <!-- Canonical URL (no query params) -->
    <link rel="canonical" href={canonicalUrl} />

    <ClientRouter />
  </head>

  <body>
    <!-- Scroll Progress Indicator -->
    <div class="scroll-progress"></div>

    <!-- Page Load Overlay -->
    <div class="page-load-overlay"></div>

    <slot />

    <!-- Scroll Animation Script -->
    <script>
      // ── Observers (created once, reused across navigations) ──────────────
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('animated');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -100px 0px' });

      const counterObserver = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const target = parseInt((entry.target as HTMLElement).dataset.count ?? '0');
            animateCounter(entry.target, target);
            counterObserver.unobserve(entry.target);
          }
        });
      }, { threshold: 0.5 });

      // ── Active timer registry for cleanup ────────────────────────────────
      const activeTimers = new Set<ReturnType<typeof setInterval>>();

      // ── Cleanup refs (module-scoped so astro:before-preparation can reach them) ──
      let removeScrollListener: (() => void) | null = null;
      let removeDelegatedListeners: (() => void) | null = null;

      // ── Parallax ─────────────────────────────────────────────────────────
      let ticking = false;

      function updateParallax() {
        const parallaxElements = document.querySelectorAll('[data-parallax]');
        const scrollY = window.pageYOffset;

        parallaxElements.forEach(el => {
          const element = el as HTMLElement;
          const speed = parseFloat(element.dataset.parallax ?? '0.5') || 0.5;
          const rect = element.getBoundingClientRect();
          const elementTop = rect.top + scrollY;
          const viewportHeight = window.innerHeight;

          if (rect.top < viewportHeight && rect.bottom > 0) {
            const offset = (scrollY - elementTop + viewportHeight / 2) * speed;
            element.style.transform = `translateY(${offset}px)`;
          }
        });

        ticking = false;
      }

      // ── Scroll Progress (guards against division by zero) ─────────────────
      function updateScrollProgress() {
        const scrollProgress = document.querySelector('.scroll-progress');
        const scrollable = document.documentElement.scrollHeight - window.innerHeight;

        if (scrollProgress) {
          const progress = scrollable > 0 ? (window.pageYOffset / scrollable) * 100 : 0;
          (scrollProgress as HTMLElement).style.width = progress + '%';
        }
      }

      // ── Counter Animation ─────────────────────────────────────────────────
      function animateCounter(element: Element, target: number, duration = 2000) {
        const increment = target / (duration / 16);
        let current = 0;

        const timer = setInterval(() => {
          current += increment;
          if (current >= target) {
            element.textContent = target + '+';
            clearInterval(timer);
            activeTimers.delete(timer);
          } else {
            element.textContent = Math.floor(current) + '+';
          }
        }, 16);

        activeTimers.add(timer);
      }

      // ── Cleanup before navigation ─────────────────────────────────────────
      document.addEventListener('astro:before-preparation', () => {
        removeScrollListener?.();
        removeScrollListener = null;
        removeDelegatedListeners?.();
        removeDelegatedListeners = null;
        activeTimers.forEach(id => clearInterval(id));
        activeTimers.clear();
      });

      // ── Setup on every page load ──────────────────────────────────────────
      document.addEventListener('astro:page-load', () => {
        // Scroll animations
        document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));

        // Counters
        document.querySelectorAll('[data-count]').forEach(counter => counterObserver.observe(counter));

        // Initial state
        updateParallax();
        updateScrollProgress();

        // Single combined scroll listener
        const handleScroll = () => {
          if (!ticking) {
            window.requestAnimationFrame(updateParallax);
            ticking = true;
          }
          updateScrollProgress();
        };
        window.addEventListener('scroll', handleScroll, { passive: true });
        removeScrollListener = () => window.removeEventListener('scroll', handleScroll);

        // Page load overlay
        const overlay = document.querySelector('.page-load-overlay');
        if (overlay) {
          overlay.classList.add('loaded');
          setTimeout(() => {
            (overlay as HTMLElement).style.display = 'none';
          }, 600);
        }

        // ── Delegated listeners — one handler per type, removed on navigation ──

        // Button ripple effect + anchor smooth scroll share one click handler
        const handleClick = (e: Event) => {
          const me = e as MouseEvent;
          const target = me.target as HTMLElement;

          // Ripple: find closest interactive element
          const btn = target.closest('button, .btn, .cta-primary, .cta-secondary') as HTMLElement | null;
          if (btn) {
            const ripple = document.createElement('span');
            const rect = btn.getBoundingClientRect();
            const size = Math.max(rect.width, rect.height);
            ripple.style.width = ripple.style.height = size + 'px';
            ripple.style.left = (me.clientX - rect.left - size / 2) + 'px';
            ripple.style.top = (me.clientY - rect.top - size / 2) + 'px';
            ripple.classList.add('ripple');
            btn.appendChild(ripple);
            setTimeout(() => ripple.remove(), 600);
          }

          // Smooth scroll: find closest anchor with hash href
          const link = target.closest('a[href^="#"]') as HTMLAnchorElement | null;
          if (link) {
            const href = link.getAttribute('href');
            if (href && href !== '#') {
              const destination = document.querySelector(href);
              if (destination) {
                e.preventDefault();
                const offsetPosition = destination.getBoundingClientRect().top + window.pageYOffset - 100;
                window.scrollTo({ top: offsetPosition, behavior: 'smooth' });
              }
            }
          }
        };

        // Form input focus animation — use capture so it fires before bubbling
        const handleFocus = (e: Event) => {
          const el = e.target as HTMLElement;
          if (el.matches('input, select, textarea')) {
            el.parentElement?.classList.add('input-focused');
          }
        };
        const handleBlur = (e: Event) => {
          const el = e.target as HTMLElement;
          if (el.matches('input, select, textarea')) {
            el.parentElement?.classList.remove('input-focused');
          }
        };

        document.addEventListener('click', handleClick);
        document.addEventListener('focus', handleFocus, true);
        document.addEventListener('blur', handleBlur, true);

        removeDelegatedListeners = () => {
          document.removeEventListener('click', handleClick);
          document.removeEventListener('focus', handleFocus, true);
          document.removeEventListener('blur', handleBlur, true);
        };
      });
    </script>
  </body>
</html>
